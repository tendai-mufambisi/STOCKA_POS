{
  "name": "stocka",
  "version": "1.1.0",
  "description": "Stocka - Retail Inventory & POS for Zimbabwe",
  "author": "Tendai Mufambisi",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run vite\" \"npm run electron:dev\"",
    "vite": "vite",
    "electron:dev": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build:web": "cross-env NODE_ENV=production BUILD_TARGET=web vite build",
    "dev:web": "cross-env BUILD_TARGET=web vite",
    "preview": "vite preview",
    "dist": "cross-env NODE_ENV=production BUILD_TARGET=desktop vite build && electron-builder",
    "release": "cross-env NODE_ENV=production BUILD_TARGET=desktop vite build && electron-builder --publish always",
    "postinstall": "electron-builder install-app-deps",
    "schema:help": "node scripts/schema-sync.js help",
    "schema:list": "node scripts/schema-sync.js list",
    "schema:new": "npx supabase migration new",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:push": "npx supabase db push",
    "db:pull": "npx supabase db pull"
  },
  "dependencies": {
    "@plick/electron-pos-printer": "^1.3.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.1",
    "bcryptjs": "^2.4.3",
    "electron-updater": "^6.3.9",
    "grep": "^0.1.0",
    "node-printer": "^1.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.8.0",
    "serialport": "^13.0.0",
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "supabase": "^2.95.2",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "co.zw.digitsdigital.stocka",
    "productName": "Stocka",
    "icon": "src/assets/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/utils/printerUtils.js",
      "src/assets/icon.png",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-printer/**",
      "node_modules/serialport/**",
      "node_modules/@serialport/**",
      "src/utils/printerUtils.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stocka"
    },
    "publish": {
      "provider": "github",
      "owner": "tendai-mufambisi",
      "repo": "STOCKA_POS"
    }
  }
}
