{
  "name": "stocka",
  "version": "1.0.0",
  "description": "Stocka - Retail Inventory & POS for Zimbabwe",
  "author": "Tendai Mufambisi",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run vite\" \"npm run electron:dev\"",
    "vite": "vite",
    "electron:dev": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "cross-env NODE_ENV=production vite build",
    "postinstall": "electron-rebuild",
    "preview": "vite preview",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "dependencies": {
    "@plick/electron-pos-printer": "^1.3.0",
    "bcryptjs": "^2.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "grep": "^0.1.0",
    "node-printer": "^1.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.8.0",
    "serialport": "^13.0.0",
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.5",
    "yarn": "^1.22.22"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^3.x.x",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^29.1.0",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "asar": true,
    "asarUnpack": [
      "node_modules/node-printer/**",
      "node_modules/serialport/**",
      "node_modules/@serialport/**",
      "src/utils/printerUtils.js"
    ],
    "appId": "com.stocka.app",
    "productName": "Stocka",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "certificateFile": null
    }
  }
}
