{
  "name": "stocka",
  "version": "1.7.0",
  "description": "Stocka - Retail Inventory & POS for Zimbabwe",
  "author": "Tendai Mufambisi",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run vite\" \"npm run electron:dev\"",
    "vite": "vite --host",
    "electron:dev": "wait-on http://localhost:5173 && cross-env NODE_ENV=development node electron-launch.js",
    "build:web": "cross-env NODE_ENV=production BUILD_TARGET=web vite build",
    "dev:web": "cross-env BUILD_TARGET=web vite",
    "preview": "vite preview",
    "dist": "cross-env NODE_ENV=production BUILD_TARGET=desktop vite build && electron-builder",
    "release": "cross-env NODE_ENV=production BUILD_TARGET=desktop vite build && electron-builder --publish always",
    "upload": "python upload-to-r2.py",
    "lint": "eslint src/",
    "postinstall": "node postinstall.js"
  },
  "dependencies": {
    "@plick/electron-pos-printer": "^1.3.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.1",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.8.9",
    "grep": "^0.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "react-is": "^19.2.7",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.8.0",
    "serialport": "^13.0.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "co.zw.digitsdigital.stocka",
    "productName": "Stocka",
    "icon": "src/assets/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/utils/printerUtils.js",
      "src/assets/icon.png",
      "src/assets/icon.ico",
      "package.json",
      "send-to-printer.ps1"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/serialport/**",
      "node_modules/@serialport/**",
      "node_modules/better-sqlite3/**",
      "send-to-printer.ps1"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Stocka",
      "include": "installer.nsh"
    },
    "publish": {
      "provider": "generic",
      "url": "https://pub-88862824ed9840ca984415fbd9e10fb1.r2.dev"
    }
  }
}
